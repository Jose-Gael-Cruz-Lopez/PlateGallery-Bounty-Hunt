# Backend configuration — copy to .env and fill in real values

ENV=dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/plategallery

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=plates

# Moderation (optional — defaults to rule_based)
MODERATION_PROVIDER=rule_based
OPENAI_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate limits
RATE_LIMIT_UPLOADS_PER_DAY=20
RATE_LIMIT_UPLOADS_PER_HOUR=5
RATE_LIMIT_VOTES_PER_MINUTE=60
